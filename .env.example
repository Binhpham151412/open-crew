# ===== MODEL CONFIG =====
# Default model cho tất cả agents
# Chọn 1 trong các option bên dưới:

# --- Option 1: MiMo (recommended, rẻ) ---
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=mimo-v2.5-pro
DEFAULT_LLM_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
DEFAULT_LLM_API_KEY=your-mimo-api-key-here

# --- Option 2: Ollama (miễn phí, local, cần GPU 8GB+) ---
# DEFAULT_LLM_PROVIDER=ollama
# DEFAULT_LLM_MODEL=qwen2.5:7b
# DEFAULT_LLM_BASE_URL=http://localhost:11434

# --- Option 3: Gemini Flash (miễn phí, có rate limit) ---
# DEFAULT_LLM_PROVIDER=gemini
# DEFAULT_LLM_MODEL=gemini-2.5-flash
# DEFAULT_LLM_API_KEY=your-gemini-api-key

# --- Option 4: Qwen (miễn phí từ Alibaba) ---
# DEFAULT_LLM_PROVIDER=openai
# DEFAULT_LLM_MODEL=qwen2.5-72b-instruct
# DEFAULT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DEFAULT_LLM_API_KEY=your-qwen-api-key

# --- Option 5: GPT-4o (đắt, chất lượng cao) ---
# DEFAULT_LLM_PROVIDER=openai
# DEFAULT_LLM_MODEL=gpt-4o
# DEFAULT_LLM_BASE_URL=https://api.openai.com/v1
# DEFAULT_LLM_API_KEY=your-openai-api-key

# Per-agent override (optional, bỏ qua = dùng default)
# PO_LLM_MODEL=mimo-v2.5-pro
# FRONTEND_DEV_LLM_MODEL=gpt-4o
# BACKEND_DEV_LLM_MODEL=gpt-4o
# SECURITY_LLM_MODEL=claude-3.5-sonnet

# Max tokens per request (0 = unlimited)
MAX_TOKENS=0

# ===== GITHUB =====
GITHUB_TOKEN=ghp_your-github-token
GITHUB_USERNAME=your-username

# ===== MCP SERVERS (optional, điền sau cũng được) =====
# GITHUB_MCP_URL=http://localhost:3001
# LINEAR_MCP_URL=http://localhost:3002
# OPENDESIGN_MCP_URL=http://localhost:3003
# OPENCODE_MCP_URL=http://localhost:3004

# ===== REDIS =====
REDIS_URL=redis://localhost:6379

# ===== AGENT CONFIG =====
AGENT_LOOP_MAX_ITERATIONS=10
AGENT_LOOP_IDLE_SLEEP=1.0
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3
